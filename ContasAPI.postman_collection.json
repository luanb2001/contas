		{
			"name": "Autenticação",
			"item": [
				{
					"name": "Login - Obter token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Login retornou status 2xx', function () {",
									"  pm.expect(pm.response.code).to.be.within(200, 299);",
									"});",
									"let json = {};",
									"try { json = pm.response.json(); } catch (e) { throw new Error('Resposta do login não é JSON válido'); }",
									"const token = json.token || json.accessToken || json.jwt;",
									"if (token) {",
									"  pm.collectionVariables.set('token', token);",
									"  pm.environment.set('token', token);",
									"}",
									"pm.test('Token salvo em variável', function () {",
									"  pm.expect(pm.collectionVariables.get('token') || pm.environment.get('token')).to.not.be.empty;",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
