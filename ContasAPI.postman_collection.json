					"name": "Importar contas via CSV",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Importação solicitada com sucesso', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
									"let protocolo = null;",
									"try {",
									"  const json = pm.response.json();",
									"  protocolo = json.id || json.protocolo || json.protocoloId || json.uuid || json;",
									"} catch (e) {",
									"  protocolo = pm.response.text();",
									"}",
									"if (typeof protocolo === 'string') { protocolo = protocolo.replace(/\\\"/g, '').trim(); }",
									"if (protocolo) { pm.collectionVariables.set('protocoloId', protocolo); pm.environment.set('protocoloId', protocolo); }"
								]
							}
						}
